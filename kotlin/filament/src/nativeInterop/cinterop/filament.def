headers = FilaTypes.h Engine.h Camera.h Material.h RenderableManager.h TransformManager.h LightManager.h Renderer.h View.h Scene.h SwapChain.h VertexBuffer.h IndexBuffer.h BufferObject.h Texture.h RenderTarget.h MorphTargetBuffer.h SkinningBuffer.h IndirectLight.h Skybox.h Stream.h Fence.h ToneMapper.h ColorGrading.h MaterialInstance.h EntityManager.h TextureSampler.h Colors.h MathUtils.h SurfaceOrientation.h
package = dev.filament.kmp.cinterop
headerFilter = *.h

# iOS Consumer Linking
linkerOpts.ios_arm64 = -lc++ -lz -framework Metal -framework UIKit -framework CoreVideo -framework QuartzCore -framework CoreGraphics -framework Foundation -weak_framework SwiftUICore -weak_framework UIUtilities
linkerOpts.ios_simulator_arm64 = -lc++ -lz -framework Metal -framework UIKit -framework CoreVideo -framework QuartzCore -framework CoreGraphics -framework Foundation -weak_framework SwiftUICore -weak_framework UIUtilities

# macOS Consumer Linking
linkerOpts.macos_arm64 = -lc++ -lz -framework Metal -framework Cocoa -framework QuartzCore -framework CoreVideo -framework AppKit -framework CoreGraphics -framework Foundation
