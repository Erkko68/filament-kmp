material {
    name : LitShadowFixture,
    shadingModel : lit,
    culling : none,
    doubleSided : true
}

fragment {
    void material(inout MaterialInputs material) {
        prepareMaterial(material);
        material.baseColor = vec4(0.85, 0.85, 0.88, 1.0);
        material.roughness = 0.7;
        material.metallic = 0.0;
    }
}

